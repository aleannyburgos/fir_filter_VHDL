library ieee;
use ieee.std_logic_1164.all;

library lpm;
use lpm.lpm_components.all;

entity fir_filter is
port( clk, clear : in std_logic;
		y : out std_logic(15 downto 0)
	);
end fir_filter;

architecture structural of fir_filter is 

signal fir_counter_out :std_logic_vector(1 downto 0);
signal fir_signal, fir_shift_0, fir_shift_1, fir_shift_2,: std_logic_vector(7 downto 0); --change to foor loop
signal fir_shift0_out, fir_shift1_out, fir_shift2_out, fir_shift3_out: std_logic_vector(7 downto 0);
signal fir_mult_xn3_out, fir_mult_xn2_out, fir_mult_xn1_out, fir_mult_xn0_out : std_logic_vector(7 downto 0);
signal fir_adder_n32_out, fir_adder_n10_out, fir_adder_out : std_logic_vector(15 downto 0);
signal clock : std_logic;

process(clk) is
begin
	delay : lpm_counter generic map(lpm_width=>2) port map(clock =>clk, cout=>clock);

fir_counter : lpm_counter
	generic map(LPM_WIDTH=>4)
	port map(clock=>clock, aclr=>clear);
	
	
fir_rom : lpm_rom
	generic map(LPM_WIDTH=>, LPM_FILE=>, LPM_WIDTHAD=>)
	port map(address=>fir_counter_out, q=>fir_signal);
	
	
fir_xn0 : lpm_shiftreg
	generic map(LPM_WIDTH=>8)
	port map(data=>fir_signal, aclr=>clear, clock=>clock, shiftout=>fir_shift_0, q=>fir_shift0_out);
	
fir_xn1 : lpm_shiftreg
	generic map(LPM_WIDTH=>8)
	port map(aclr=>clear, clock=>clock, shiftout=>fir_shift_1, q=>fir_shift1_out, shiftin=>fir_shift_0);
	
fir_xn2 : lpm_shiftreg
	generic map(LPM_WIDTH=>8)
	port map(aclr=>clear, clock=>clock, shiftout=>fir_shift_2, q=>fir_shift2_out, shiftin=>fir_shift_1);

fir_xn3 : lpm_shiftreg
	generic map(LPM_WIDTH=>8)
	port map(aclr=>clear, clock=>clock, q=>fir_shift3_out, shiftin=>fir_shift_2);
	
	
fir_mult_xn : lpm_mult
	generic map(LPM_WIDTHA=>8,LPM_WIDTHB=>8,LPM_WIDTHP=>16)
	port map(dataa=>fir_shift0_out, datab=>h0, clock=>clock, aclr => clear, result=> fir_mult_xn0_out);
	
fir_mult_xn1 : lpm_mult
	generic map(LPM_WIDTHA=>8,LPM_WIDTHB=>8,LPM_WIDTHP=>16)
	port map(dataa=>fir_shift1_out, datab=>h1, clock=>clock, aclr => clear, result=> fir_mult_xn1_out);
	
fir_mult_xn2 : lpm_mult
	generic map(LPM_WIDTHA=>8,LPM_WIDTHB=>8,LPM_WIDTHP=>16)
	port map(dataa=>fir_shift2_out, datab=>h2, clock=>clock, aclr => clear, result=> fir_mult_xn2_out);
	
fir_mult_xn3 : lpm_mult
	generic map(LPM_WIDTHA=>8,LPM_WIDTHB=>8,LPM_WIDTHP=>16)
	port map(dataa=>fir_shift3_out, datab=>h3, clock=>clock, aclr => clear, result=> fir_mult_xn3_out);
	

fir_adder_n32 : lpm_add_sub
	generic map(LPM_WIDTH=>16)
	port map(clock=>clock, aclr=>clear, result=>fir_adder_n32_out, dataa=>fir_mult_xn3_out, datab=>fir_mult_xn2_out);
	
fir_adder_n10 : lpm_add_sub
	generic map(LPM_WIDTH=>16)
	port map(clock=>clock, aclr=>clear, result=>fir_adder_n10_out, dataa=>fir_mult_xn1_out, datab=>fir_mult_xn0_out);
	
fir_adder : lpm_add_sub
	generic map(LPM_WIDTH=>16)
	port map(clock=>clock, aclr=>clear, result=>fir_adder_out, dataa=>fir_adder_n32_out, datab=>fir_adder_n10_out);
	
	
fir_result_reg : lpm_ff
	generic map(LPM_WIDTH=>16)
	port map(q=>y, data=>fir_adder_out, aclr=>clear, clock=>clock);
	
end structural;
	